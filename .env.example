# KYRONIX S.E.N.O — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ─────────────────────────────────────────────────────────────

# Supabase project URL (found in: Supabase Dashboard → Settings → API)
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# Supabase anonymous/public key (safe to expose in the browser)
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── App Configuration ────────────────────────────────────────

# App display name (used in page title / brand)
VITE_APP_NAME=KYRONIX S.E.N.O

# Supabase Storage bucket for file uploads (create it in the dashboard)
VITE_STORAGE_BUCKET=project-wg-files

# Admin API base URL (default: /api/admin)
# VITE_ADMIN_API_BASE_URL=/api/admin

# ── WebRTC / TURN (Optional) ────────────────────────────────

# TURN server URLs for reliable 1:1 calls in production.
# The frontend ships with a Metered fallback which exposes credentials in the bundle.
# Set these to override with your own TURN/TURNS credentials.
# VITE_TURN_URLS=turn:global.relay.metered.ca:80,turns:global.relay.metered.ca:443?transport=tcp
# VITE_TURN_USERNAME=your-metered-username
# VITE_TURN_CREDENTIAL=your-metered-credential

# Full ICE server JSON override (precedence over VITE_TURN_*)
# VITE_WEBRTC_ICE_SERVERS=[{"urls":"stun:stun.l.google.com:19302"}]

# ── Supabase Server-side (NEVER prefix with VITE_) ──────────

# Service role key (found in: Supabase Dashboard → Settings → API)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Test Credentials (Cypress / Integration Tests) ──────────

# Default test password for all test users
TEST_USER_PASSWORD=Teste@12345

# Password for requested profiles script
REQUESTED_PROFILES_PASSWORD=Teste@12345

# Cypress test credentials (one per profile)
CYPRESS_ADMIN_PASSWORD=Teste@12345
CYPRESS_TEACHER_PASSWORD=Teste@12345
CYPRESS_STUDENT_PASSWORD=Teste@12345
CYPRESS_COORDINATOR_PASSWORD=Teste@12345
CYPRESS_SECRETARY_PASSWORD=Teste@12345